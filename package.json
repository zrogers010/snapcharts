{
  "name": "snapcharts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "smoke:production": "SMOKE_BASE_URL=${SMOKE_BASE_URL:-https://snapcharts.com} node scripts/smoke-routes.mjs",
    "start": "next start"
  },
  "dependencies": {
    "lightweight-charts": "^4.1.7",
    "next": "^15.5.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yahoo-finance2": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.2",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
